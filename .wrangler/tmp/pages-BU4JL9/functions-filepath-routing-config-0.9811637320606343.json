{
  "routes": [
    {
      "routePath": "/api/auth/login",
      "mountPath": "/api/auth",
      "method": "POST",
      "module": [
        "api/auth/login.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/orders/:id",
      "mountPath": "/api/orders",
      "method": "PUT",
      "module": [
        "api/orders/[id].js:onRequestPut"
      ]
    },
    {
      "routePath": "/api/products/:id",
      "mountPath": "/api/products",
      "method": "DELETE",
      "module": [
        "api/products/[id].js:onRequestDelete"
      ]
    },
    {
      "routePath": "/api/products/:id",
      "mountPath": "/api/products",
      "method": "PUT",
      "module": [
        "api/products/[id].js:onRequestPut"
      ]
    },
    {
      "routePath": "/api/orders",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/orders.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/orders",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/orders.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/products",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/products.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/products",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/products.js:onRequestPost"
      ]
    }
  ],
  "baseURL": "/"
}